  {
    "model": "talos_parietal.tooldefinition",
    "pk": 1,
    "fields": {
      "name": "mcp_read_file",
      "description": "Reads a specific line range from a local file. Use this to examine source code, config files, or logs. Efficient for large files by reading only relevant chunks.",
      "is_async": true,
      "created": "2026-02-18T12:00:00Z",
      "modified": "2026-02-18T12:00:00Z"
    }
  },
  {
    "model": "talos_parietal.tooldefinition",
    "pk": 2,
    "fields": {
      "name": "mcp_grep",
      "description": "Recursively searches for a regex pattern in files. Equivalent to 'grep -r'. Returns file paths and line numbers. Use '.' as path to search the entire project.",
      "is_async": true,
      "created": "2026-02-18T12:00:00Z",
      "modified": "2026-02-18T12:00:00Z"
    }
  },
  {
    "model": "talos_parietal.tooldefinition",
    "pk": 3,
    "fields": {
      "name": "mcp_list_files",
      "description": "Lists files and directories at a specific path. Use this to explore the project structure or verify file existence.",
      "is_async": true,
      "created": "2026-02-18T12:00:00Z",
      "modified": "2026-02-18T12:00:00Z"
    }
  },
  {
    "model": "talos_parietal.tooldefinition",
    "pk": 4,
    "fields": {
      "name": "mcp_update_blackboard",
      "description": "Writes variables to the execution Blackboard. Use this to affect the routing logic of the Hydra Graph (e.g. set 'correction_strategy') or pass data to downstream agents.",
      "is_async": true,
      "created": "2026-02-18T12:00:00Z",
      "modified": "2026-02-18T12:00:00Z"
    }
  },
  {
    "model": "talos_parietal.tooldefinition",
    "pk": 5,
    "fields": {
      "name": "mcp_inspect_record",
      "description": "Returns the schema and field sizes of a database record. MANDATORY: Call this before reading any database field to ensure you do not load massive text blobs blindly.",
      "is_async": true,
      "created": "2026-02-18T12:00:00Z",
      "modified": "2026-02-18T12:00:00Z"
    }
  },
  {
    "model": "talos_parietal.tooldefinition",
    "pk": 6,
    "fields": {
      "name": "mcp_read_record_field",
      "description": "Reads a segment of text from a specific database field (like 'spell_log' or 'source_code'). Requires 'start_line' and 'max_lines' to handle large data efficiently.",
      "is_async": true,
      "created": "2026-02-18T12:00:00Z",
      "modified": "2026-02-18T12:00:00Z"
    }
  },
  {
    "model": "talos_parietal.tooldefinition",
    "pk": 7,
    "fields": {
      "name": "mcp_search_record_field",
      "description": "Searches a large database text field for a regex pattern. Use this to find error messages or specific log entries without reading the entire record.",
      "is_async": true,
      "created": "2026-02-18T12:00:00Z",
      "modified": "2026-02-18T12:00:00Z"
    }
  },
  {
    "model": "talos_parietal.tooldefinition",
    "pk": 8,
    "fields": {
      "name": "mcp_query_model",
      "description": "Queries the database for records matching specific criteria. Supports simple 'filters' (dict) or complex 'q_string' (Q objects). Use 'action=count' to check volume before listing.",
      "is_async": true,
      "created": "2026-02-18T12:00:00Z",
      "modified": "2026-02-18T12:00:00Z"
    }
  },
  {
    "model": "talos_parietal.tooldefinition",
    "pk": 9,
    "fields": {
      "name": "mcp_search_memory",
      "description": "Searches the Cortex (Long-Term Memory) for similar past issues, solutions, or patterns. Use this early in your process to avoid repeating known mistakes.",
      "is_async": true,
      "created": "2026-02-18T12:00:00Z",
      "modified": "2026-02-18T12:00:00Z"
    }
  },
  {
    "model": "talos_parietal.tooldefinition",
    "pk": 10,
    "fields": {
      "name": "mcp_save_memory",
      "description": "Saves a valuable finding, fix, or pattern to Long-Term Memory. If you solve a hard problem, save it here so future agents know the solution.",
      "is_async": true,
      "created": "2026-02-18T12:00:00Z",
      "modified": "2026-02-18T12:00:00Z"
    }
  },
  {
    "model": "talos_parietal.tooldefinition",
    "pk": 11,
    "fields": {
      "name": "mcp_conclude_session",
      "description": "Finalizes the session and submits your report. MANDATORY: You must call this tool to end your turn. It triggers the next step in the workflow.",
      "is_async": true,
      "created": "2026-02-18T12:00:00Z",
      "modified": "2026-02-18T12:00:00Z"
    }
  },
