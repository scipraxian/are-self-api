# Are-Self environment configuration
#
# Copy this file to `.env` (same directory) and fill in your own values.
# `.env` is listed in `.gitignore` and must NEVER be committed.
#
# All keys here are OPTIONAL for a first install — the defaults in
# config/settings.py work out of the box against the Docker Compose
# stack. You only need to set these if you want to override the default
# behaviour or add a cloud provider.

# Daphne ASGI worker threads. Raise this if you have a lot of
# concurrent WebSocket clients. Default: 20.
ASGI_THREADS=20

# OpenRouter API key. Only needed if you plan to use cloud models as
# failover when your local Ollama can't handle a job. Get one from
# https://openrouter.ai/keys — starts with `sk-or-v1-`.
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
